---
import { render, getEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import FireSafetyNav from '../../components/FireSafetyNav.astro';

const entry = await getEntry('pages', 'fire-safety-home-hardening');
const { Content } = await render(entry);
---

<PageLayout title={entry.data.title} description={entry.data.description}>
  <FireSafetyNav current="home-hardening" />
  <Content />
</PageLayout>
