---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';

const allEvents = await getCollection('events');
const sorted = allEvents.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcoming = sorted.filter(e => e.data.date >= today);
const past = sorted.filter(e => e.data.date < today).reverse();
---

<BaseLayout title="Events | HDCA">
  <h1 class="text-3xl font-bold text-navy mb-8">Events</h1>

  {upcoming.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-bold text-navy mb-4">Upcoming Events</h2>
      <div class="grid gap-4">
        {upcoming.map(event => (
          <EventCard
            id={event.id}
            title={event.data.title}
            date={event.data.date}
            time={event.data.time}
            location={event.data.location}
            description={event.data.description}
          />
        ))}
      </div>
    </section>
  )}

  {upcoming.length === 0 && (
    <p class="text-gray-600 mb-12">No upcoming events. Check back soon!</p>
  )}

  {past.length > 0 && (
    <section>
      <h2 class="text-xl font-bold text-gray-500 mb-4">Past Events</h2>
      <div class="space-y-3">
        {past.map(event => {
          const formatted = event.data.date.toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC',
          });
          return (
            <a href={`/events/${event.id}`} class="block text-gray-500 hover:text-navy no-underline transition">
              <span class="text-sm">{formatted}</span>
              <span class="mx-2">&mdash;</span>
              <span>{event.data.title}</span>
            </a>
          );
        })}
      </div>
    </section>
  )}
</BaseLayout>
