---
const navItems = [
  { label: 'Home', href: '/' },
  {
    label: 'About',
    href: '/about',
    children: [
      { label: 'Board', href: '/about/board' },
      { label: 'Bylaws', href: '/about/bylaws' },
      { label: 'Government', href: '/about/government' },
    ],
  },
  {
    label: 'Fire Safety',
    href: '/fire-safety',
    children: [
      { label: 'Overview', href: '/fire-safety' },
      { label: 'Home Hardening', href: '/fire-safety/home-hardening' },
      { label: 'Legislation', href: '/fire-safety/legislation' },
    ],
  },
  { label: 'Events', href: '/events' },
  { label: 'News', href: '/news' },
  {
    label: 'Community',
    href: '/community',
    children: [
      { label: 'Map', href: '/community/map' },
      { label: 'Libraries', href: '/community/libraries' },
      { label: 'Photos', href: '/community/photos' },
    ],
  },
  { label: 'Archive', href: '/archive' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="bg-white border-b-3 border-gold sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
    <!-- Site name -->
    <a href="/" class="text-navy font-bold text-xl tracking-tight no-underline hover:text-navy">
      Hollywood<span class="text-gold">Dell</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
      {navItems.map((item) => (
        <div class="relative group">
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-semibold text-navy no-underline hover:text-gold-dark transition-colors inline-flex items-center gap-1"
          >
            {item.label}
            {item.children && (
              <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
          {item.children && (
            <div class="absolute left-0 top-full pt-1 hidden group-hover:block">
              <div class="bg-white border border-gray-200 rounded shadow-lg py-1 min-w-44">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-sm text-navy no-underline hover:bg-warm-gray hover:text-gold-dark transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 text-navy hover:text-gold-dark"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-gray-200 bg-white">
    <nav class="max-w-6xl mx-auto px-4 py-3 space-y-1" aria-label="Mobile navigation">
      {navItems.map((item) => (
        <div>
          {item.children ? (
            <div>
              <button
                class="mobile-dropdown-btn w-full text-left px-3 py-2 text-sm font-semibold text-navy hover:text-gold-dark flex items-center justify-between"
                aria-expanded="false"
              >
                {item.label}
                <svg class="w-3 h-3 opacity-50 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="mobile-dropdown hidden pl-4">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-3 py-2 text-sm text-navy no-underline hover:text-gold-dark"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="block px-3 py-2 text-sm font-semibold text-navy no-underline hover:text-gold-dark"
            >
              {item.label}
            </a>
          )}
        </div>
      ))}
    </nav>
  </div>
</header>

<script>
  // Mobile hamburger toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden');
    hamburgerIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    menuBtn.setAttribute('aria-expanded', isOpen === false ? 'true' : 'false');
  });

  // Mobile dropdown toggles
  document.querySelectorAll('.mobile-dropdown-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const dropdown = btn.nextElementSibling;
      const arrow = btn.querySelector('svg');
      dropdown?.classList.toggle('hidden');
      arrow?.classList.toggle('rotate-180');
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });
</script>
