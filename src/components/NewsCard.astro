---
interface Props {
  id: string;
  title: string;
  date: Date;
  author: string;
  excerpt: string;
}

const { id, title, date, author, excerpt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<a href={`/news/${id}`} class="group block no-underline">
  <article class="border-b border-gray-200 py-5">
    <h3 class="text-lg font-bold text-navy group-hover:text-teal-dark transition-colors m-0 leading-snug">{title}</h3>
    <div class="mt-1 text-sm text-gray-500">
      <time datetime={date.toISOString().split('T')[0]}>{formattedDate}</time>
      <span class="mx-1">&middot;</span>
      <span>{author}</span>
    </div>
    <p class="mt-2 text-sm text-gray-700 m-0 leading-relaxed">{excerpt}</p>
  </article>
</a>
