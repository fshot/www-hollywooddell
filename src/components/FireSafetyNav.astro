---
interface Props {
  current: 'overview' | 'home-hardening' | 'legislation';
}

const { current } = Astro.props;

const links = [
  { label: 'Overview', href: '/fire-safety', key: 'overview' as const },
  { label: 'Home Hardening', href: '/fire-safety/home-hardening', key: 'home-hardening' as const },
  { label: 'Legislation', href: '/fire-safety/legislation', key: 'legislation' as const },
];
---

<nav aria-label="Fire Safety section" class="mb-8 border-b border-gray-200 not-prose">
  <ul class="flex gap-1 -mb-px">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class:list={[
            'inline-block px-4 py-2 text-sm font-semibold no-underline transition-colors border-b-2',
            current === link.key
              ? 'border-gold text-gold-dark'
              : 'border-transparent text-navy/60 hover:text-navy hover:border-gray-300',
          ]}
          aria-current={current === link.key ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
