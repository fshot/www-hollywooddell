---
interface Props {
  heading: string;
  subheading?: string;
  backgroundImage: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
}

const { heading, subheading, backgroundImage, primaryCta, secondaryCta } = Astro.props;
---

<section
  class="relative flex items-center justify-center min-h-[70vh] bg-cover bg-center"
  style={`background-image: url('${backgroundImage}');`}
>
  <div class="absolute inset-0 bg-navy/65"></div>
  <div class="relative z-10 text-center px-4 py-20 max-w-3xl mx-auto">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4">
      {heading}
    </h1>
    {subheading && (
      <p class="text-lg sm:text-xl text-white/90 mb-8">{subheading}</p>
    )}
    {(primaryCta || secondaryCta) && (
      <div class="flex flex-wrap gap-4 justify-center">
        {primaryCta && (
          <a
            href={primaryCta.href}
            class="inline-block px-6 py-3 bg-gold text-navy font-bold rounded-lg no-underline hover:bg-gold-dark transition-colors"
          >
            {primaryCta.text}
          </a>
        )}
        {secondaryCta && (
          <a
            href={secondaryCta.href}
            class="inline-block px-6 py-3 bg-white/15 text-white font-bold rounded-lg border-2 border-white/40 no-underline hover:bg-white/25 transition-colors"
          >
            {secondaryCta.text}
          </a>
        )}
      </div>
    )}
  </div>
</section>
